<div class="container mx-auto py-20">
  <div class="text-center animate__animated animate__fadeInUp animate__delay-100ms" style="animation-name: fadeInUp;">
    <p class="border-b border-gray-300 poppins text-primary" style='font-size: x-large;'>Food Menu</p>
  </div>
  <div class="animate__animated animate__fadeInUp animate__delay-100ms" style="animation-name: fadeInUp;">
    <div class="tab-content">
      <div id="tab-1" class="mt-5 tab-pane fade in active">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <% @food_items.each do |food_item| %>
            <div class="row flex justify-between items-center">
              <div class="w-2/3 flex items-center">
                <%= image_tag(food_item.image, alt: food_item.name, class: "w-20 h-20 rounded") %>
                <div class="w-full ml-4">
                  <h5 class="border-b border-gray-300 pb-2 text-gray-800">
                    <span><%= food_item.name %></span>
                  </h5>
                  <div style="height: 60px; overflow: hidden;">
                    <small class="italic text-gray-600"><%= food_item.description %></small>
                  </div>
                </div>
              </div>
              <div class="w-1/3 flex justify-center items-center">
                <span class="text-primary">$<%= number_to_currency(food_item.price, precision: 2) %></span>
                <%= link_to "Add to Cart", root_path, class: "bg-primary text-white px-2 py-1 focus:outline-none poppins rounded-full ml-4" %>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>