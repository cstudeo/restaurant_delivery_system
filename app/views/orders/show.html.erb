<div class="container mx-auto p-4">
  <div class="bg-white p-6 rounded-lg shadow-md">
    <h1 class="text-3xl font-semibold mb-4">Order Details</h1>

    <div class="mb-6">
      <h2 class="text-xl font-semibold mb-2">Order Information</h2>
      <p><strong>Order ID:</strong> <%= @order.id %></p>
      <p><strong>Date:</strong> <%= l(@order.created_at.in_time_zone, format: :long) %></p>
    </div>

    <div class="mb-6">
      <h2 class="text-xl font-semibold mb-2">Carrier Information</h2>
      <p><strong>Name:</strong> <%= @order.carrier.first_name %> <%= @order.carrier.last_name %></p>
      <p><strong>Email:</strong> <%= @order.carrier.email %></p>
      <p><strong>Phone Number:</strong> <%= @order.carrier.phone_number %></p>
    </div>

    <div class="mb-6">
      <h2 class="text-xl font-semibold mb-2">Restaurant Information</h2>
      <p><strong>Name:</strong> <%= @order.restaurant.name %></p>
    </div>

    <div>
      <h2 class="text-xl font-semibold mt-5">Order Items</h2>
      <ul>
        <% @order.order_items.each do |order_item| %>
          <li class="flex items-center justify-between border-b border-gray-300 py-2">
            <div class="flex items-center">
              <%= cl_image_tag(order_item.food_item.picture.key, alt: order_item.food_item.name, class: "w-10 h-10 object-cover mr-2") %>
              <div>
                <h3><%= order_item.food_item.name %></h3>
                <p><%= order_item.quantity %> x $<%= order_item.food_item.price %></p>
              </div>
            </div>
            <p>$<%= order_item.total %></p>
          </li>
        <% end %>
      </ul>
    </div>

    <div class="mt-6">
      <p class="text-xl font-semibold">Total Amount: $<%= @order.total_amount %></p>
    </div>
  </div>
</div>
