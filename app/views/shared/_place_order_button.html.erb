<div class="grid text-center ml-3 m-5">  
  <% if user_signed_in? %>
    <button data-modal-target="default-modal" data-modal-toggle="default-modal" style= 'width: -webkit-fill-available;' class= 'bg-red-600 px-6 py-3 text-white poppins rounded-full ring-red-300 focus:outline-none focus:ring-4 transform transition duration-700 hover:scale-105' type="button">
        Place Order
    </button>
  <% else %>
    <%= button_to 'Place Order', orders_path, method: :post, style: 'width: -webkit-fill-available;', class: 'bg-red-600 px-6 py-3 text-white poppins rounded-full ring-red-300 focus:outline-none focus:ring-4 transform transition duration-700 hover:scale-105' %>
  <% end %>
</div>